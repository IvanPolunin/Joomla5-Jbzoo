<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Selectcity\Component\Selectcity\Administrator\Field">
  <fieldset>
    <field name="id" type="text" readonly="true" class="readonly" default="0" description="JGLOBAL_FIELD_ID_DESC"/>
    <field name="state" default="1" type="list" label="JSTATUS" description="JFIELD_PUBLISHED_DESC" class="inputbox" size="1">
      <option value="1">JPUBLISHED</option>
      <option value="0">JUNPUBLISHED</option>
      <option value="2">JARCHIVED</option>
      <option value="-2">JTRASHED</option>
    </field>
    
    <field name="ordering"/>
    <field name="checked_out" type="hidden" filter="unset"/>
    <field name="checked_out_time" type="hidden" filter="unset"/>
    <field name="created_by" type="createdby" default="0" label="JGLOBAL_FIELD_CREATED_BY_LABEL" description="JGLOBAL_FIELD_CREATED_BY_DESC" hidden="true" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_CREATED_BY"/>
    <field name="modified_by" type="modifiedby" default="0" label="JGLOBAL_FIELD_MODIFIED_BY_LABEL" description="JGLOBAL_FIELD_MODIFIED_BY_DESC" hidden="true" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_MODIFIED_BY"/>
    
    <field name="city_allias" type="text" class="inputbox" generator="name_city" label="COM_SELECTCITY_FORM_LBL_SELECTCITY_CITY_ALLIAS" description="COM_SELECTCITY_FORM_DESC_SELECTCITY_CITY_ALLIAS" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_CITY_ALLIAS"/>
    
    <field name="name_city" filter="safehtml" type="text" required="true" label="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_CITY" description="COM_SELECTCITY_FORM_DESC_SELECTCITY_NAME_CITY" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_CITY"/>
    <field name="name_country" filter="safehtml" type="text" label="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_COUNTRY" description="COM_SELECTCITY_FORM_DESC_SELECTCITY_NAME_COUNTRY" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_COUNTRY"/>
    <field name="name_region" filter="safehtml" type="text" label="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_REGION" description="COM_SELECTCITY_FORM_DESC_SELECTCITY_NAME_REGION" hint="COM_SELECTCITY_FORM_LBL_SELECTCITY_NAME_REGION"/>
    <field name="version_note" type="text" label="JGLOBAL_FIELD_VERSION_NOTE_LABEL" description="JGLOBAL_FIELD_VERSION_NOTE_DESC" class="inputbox" size="45" labelclass="control-label"/>
  </fieldset>
</form>
